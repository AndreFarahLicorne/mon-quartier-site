---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import BoardMockup from '../components/BoardMockup.astro';

const title = "Jeu de plateau personnalisé pour anniversaire — Cadeau unique";
const description = "Créez un jeu de société personnalisé pour un anniversaire inoubliable. Les lieux marquants d'une vie sur un plateau de jeu.";
---

<Layout title={title} description={description}>
    <Navbar />
    <main>
        <section class="landing-hero">
            <div class="container">
                <Breadcrumb items={[
                    { label: "Accueil", href: "/" },
                    { label: "Jeu personnalisé anniversaire" }
                ]} />
                <h1>Un jeu de plateau personnalisé pour un anniversaire inoubliable</h1>
                <p class="landing-subtitle">Retracez les lieux marquants d'une vie sur un plateau de jeu unique. Le cadeau parfait pour un 30e, 40e, 50e ou 60e anniversaire.</p>
                <a href="#devis" class="btn btn-primary btn-lg">Demander un devis gratuit</a>
            </div>
            <div class="landing-visual">
                <BoardMockup />
            </div>
        </section>

        <!-- Pourquoi un jeu pour un anniversaire -->
        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2>Pourquoi offrir un jeu personnalisé pour un anniversaire ?</h2>
                    <p>Un cadeau qui traverse le temps et rassemble les générations.</p>
                </div>
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon">🎂</div>
                        <h3>Un voyage dans le temps</h3>
                        <p>Chaque case du plateau est un lieu qui a compté : l'école primaire, le premier appartement, le lieu de travail, la maison de vacances... Une vie entière résumée en un jeu.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">👨‍👩‍👧‍👦</div>
                        <h3>Toute la famille réunie</h3>
                        <p>Enfants, petits-enfants, amis de longue date... Tout le monde découvre ou redécouvre des lieux chargés de souvenirs. Les anecdotes fusent, les rires aussi.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">💝</div>
                        <h3>L'émotion garantie</h3>
                        <p>Quand le destinataire découvre son plateau avec les rues de son enfance, les larmes de joie sont au rendez-vous. Un cadeau qui touche en plein coeur.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Les âges et les cases -->
        <section class="section section-cream">
            <div class="container">
                <div class="section-header">
                    <h2>Un jeu qui s'adapte à chaque âge</h2>
                    <p>30 ans, 40 ans, 50 ans, 60 ans et plus... chaque décennie a ses lieux emblématiques.</p>
                </div>
                <div class="ages-grid">
                    <div class="age-card">
                        <span class="age-number">30 ans</span>
                        <p>La fac, le premier appart', le bar préféré, le premier job, les voyages entre amis...</p>
                    </div>
                    <div class="age-card">
                        <span class="age-number">40 ans</span>
                        <p>La maternité, l'école des enfants, la maison, le parc du dimanche, le resto en amoureux...</p>
                    </div>
                    <div class="age-card">
                        <span class="age-number">50 ans</span>
                        <p>Le bureau, la résidence secondaire, le stade, le marché du samedi, la salle de sport...</p>
                    </div>
                    <div class="age-card">
                        <span class="age-number">60 ans</span>
                        <p>L'école d'enfance, le lieu de rencontre, la maison familiale, le jardin, les petits-enfants...</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Exemple concret Marc -->
        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2>L'histoire de Marc, 50 ans</h2>
                    <p>Quand ses enfants ont voulu marquer le coup.</p>
                </div>
                <div class="exemple-container">
                    <div class="exemple-content">
                        <p class="exemple-intro">Pour les 50 ans de leur père, les trois enfants de Marc ont voulu un cadeau à la hauteur. Un cadeau qui résumerait une vie riche en aventures, de Marseille à Paris en passant par Montréal.</p>
                        <div class="exemple-details">
                            <div class="exemple-item">
                                <strong>Le défi :</strong>
                                <span>Résumer 50 ans de vie en un seul plateau, avec les lieux qui ont façonné Marc.</span>
                            </div>
                            <div class="exemple-item">
                                <strong>Les cases :</strong>
                                <span>L'école Pasteur à Marseille (enfance), le Vieux-Port (adolescence), la fac de Montpellier (études), Montréal (année à l'étranger), le siège de son entreprise à Paris (carrière), la maison de Provence (week-ends en famille).</span>
                            </div>
                            <div class="exemple-item">
                                <strong>Le résultat :</strong>
                                <span>Marc a découvert son jeu devant 40 convives. Il a reconnu chaque lieu, raconté des anecdotes que même ses enfants ne connaissaient pas. Un moment inoubliable.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Témoignage Sophie L. -->
        <section class="section section-dark">
            <div class="container">
                <div class="section-header">
                    <h2>Ce qu'en disent nos clients</h2>
                </div>
                <div class="testimonial-highlight">
                    <article class="testimonial-card testimonial-featured">
                        <div class="testimonial-stars" aria-label="5 étoiles sur 5">★★★★★</div>
                        <p class="testimonial-text">"On a offert le jeu à mon père pour ses 60 ans. Il était ému aux larmes ! Chaque case lui rappelait un souvenir. Le plus beau cadeau qu'on ait pu lui faire."</p>
                        <div class="testimonial-author">
                            <div class="testimonial-avatar">S</div>
                            <div>
                                <strong>Sophie L.</strong>
                                <span>Cadeau anniversaire</span>
                            </div>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <!-- Comment ça marche -->
        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2>Comment créer votre jeu d'anniversaire ?</h2>
                    <p>Un processus simple en 3 étapes pour un résultat sur mesure.</p>
                </div>
                <div class="steps-container">
                    <div class="step">
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <h3>Partagez les souvenirs</h3>
                            <p>Listez les lieux importants de la vie de la personne : villes, rues, bâtiments, parcs... Ajoutez des anecdotes pour rendre chaque case vivante.</p>
                        </div>
                    </div>
                    <div class="step">
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <h3>Validez la maquette</h3>
                            <p>Notre équipe transforme vos souvenirs en un plateau unique. Vous vérifiez chaque détail et ajustez selon vos envies avant la fabrication.</p>
                        </div>
                    </div>
                    <div class="step">
                        <div class="step-number">3</div>
                        <div class="step-content">
                            <h3>Offrez la surprise</h3>
                            <p>Recevez votre jeu sous 3 à 4 semaines, prêt à être offert. L'émotion est garantie au moment du déballage !</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Maillage interne -->
        <section class="section section-cream">
            <div class="container">
                <div class="section-header">
                    <h2>Découvrez nos autres créations</h2>
                    <p>Un jeu personnalisé pour chaque occasion.</p>
                </div>
                <div class="links-grid">
                    <a href="/jeu-personnalise-mariage/" class="link-card">
                        <span class="link-icon">💍</span>
                        <h3>Jeu pour mariage</h3>
                        <p>Votre histoire d'amour transformée en jeu de société.</p>
                    </a>
                    <a href="/cadeau-personnalise-original/" class="link-card">
                        <span class="link-icon">🎁</span>
                        <h3>Cadeau personnalisé original</h3>
                        <p>Le cadeau qui sort vraiment de l'ordinaire pour toutes les occasions.</p>
                    </a>
                    <a href="/" class="link-card">
                        <span class="link-icon">🏘️</span>
                        <h3>Retour à l'accueil</h3>
                        <p>Découvrez tout l'univers Mon Quartier et nos créations.</p>
                    </a>
                </div>
            </div>
        </section>

        <!-- Formulaire de devis -->
        <section class="section section-cream" id="devis">
            <div class="container">
                <div class="section-header">
                    <h2>Demandez votre devis gratuit</h2>
                    <p>Décrivez-nous votre projet de jeu d'anniversaire et recevez une proposition personnalisée sous 48h.</p>
                </div>
                <div class="form-container">
                    <form id="devisForm" class="devis-form" aria-label="Formulaire de demande de devis" action="https://api.web3forms.com/submit" method="POST">
                        <input type="hidden" name="access_key" value="079156f8-d186-4ef3-99d5-28c6b1973be9">
                        <input type="hidden" name="subject" value="Nouvelle demande de devis — Jeu d'anniversaire">
                        <input type="hidden" name="redirect" value="https://monquartier-jeu.fr/jeu-personnalise-anniversaire/#devis">
                        <input type="checkbox" name="botcheck" class="hidden" style="display:none">
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="nom">Nom complet *</label>
                                <input type="text" id="nom" name="nom" required placeholder="Votre nom" autocomplete="name">
                            </div>
                            <div class="form-group">
                                <label for="email">Email *</label>
                                <input type="email" id="email" name="email" required placeholder="votre@email.com" autocomplete="email">
                            </div>
                            <div class="form-group">
                                <label for="telephone">Téléphone</label>
                                <input type="tel" id="telephone" name="telephone" placeholder="06 12 34 56 78" autocomplete="tel">
                            </div>
                            <div class="form-group">
                                <label for="occasion">Type de projet *</label>
                                <select id="occasion" name="occasion" required>
                                    <option value="" disabled>Choisissez une occasion</option>
                                    <option value="quartier">Jeu de quartier / ville</option>
                                    <option value="mariage">Mariage</option>
                                    <option value="anniversaire" selected>Anniversaire</option>
                                    <option value="entreprise">Entreprise / Team building</option>
                                    <option value="association">Association / Comité</option>
                                    <option value="cadeau">Cadeau personnalisé</option>
                                    <option value="autre">Autre</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="quantite">Nombre d'exemplaires souhaités</label>
                                <select id="quantite" name="quantite">
                                    <option value="" disabled selected>Sélectionnez une quantité</option>
                                    <option value="1">1 exemplaire</option>
                                    <option value="2-5">2 à 5 exemplaires</option>
                                    <option value="6-20">6 à 20 exemplaires</option>
                                    <option value="21-50">21 à 50 exemplaires</option>
                                    <option value="51-100">51 à 100 exemplaires</option>
                                    <option value="100+">Plus de 100 exemplaires</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group form-group-full">
                            <label for="message">Décrivez votre projet *</label>
                            <textarea id="message" name="message" rows="5" required placeholder="Parlez-nous de l'anniversaire, des lieux marquants de la vie de la personne, de vos idées..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg btn-submit">Envoyer ma demande de devis</button>
                        <p class="form-note">* Champs obligatoires — Réponse garantie sous 48h</p>
                    </form>
                    <div id="formSuccess" class="form-success" hidden>
                        <div class="success-icon">✅</div>
                        <h3>Demande envoyée !</h3>
                        <p>Merci pour votre demande. Nous vous répondrons sous 48h avec une proposition personnalisée.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />

    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "Jeu de plateau personnalisé anniversaire",
        "description": description,
        "provider": {
            "@type": "LocalBusiness",
            "name": "Mon Quartier",
            "url": "https://monquartier-jeu.fr"
        },
        "areaServed": {
            "@type": "Country",
            "name": "France"
        },
        "serviceType": "Création de jeu de plateau personnalisé pour anniversaire"
    })} />
</Layout>

<style>
    .landing-hero {
        padding: 140px 0 60px;
        background: linear-gradient(135deg, #fef9ef 0%, #faf6f1 50%, #f0f7f0 100%);
    }
    .landing-hero h1 {
        font-family: var(--font-heading);
        font-size: 2.8rem;
        color: var(--color-primary-dark);
        max-width: 700px;
        margin-bottom: 16px;
    }
    .landing-subtitle {
        font-size: 1.2rem;
        color: var(--color-text-light);
        max-width: 600px;
        line-height: 1.7;
        margin-bottom: 32px;
    }
    .ages-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }
    .age-card {
        background: var(--color-bg);
        padding: 28px 24px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        text-align: center;
        transition: all var(--transition);
    }
    .age-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }
    .age-number {
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-cta);
        display: block;
        margin-bottom: 12px;
    }
    .age-card p {
        font-size: 0.9rem;
        color: var(--color-text-light);
        line-height: 1.6;
    }
    .exemple-container {
        max-width: 760px;
        margin: 0 auto;
    }
    .exemple-content {
        background: var(--color-bg);
        padding: 40px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
    }
    .exemple-intro {
        font-size: 1.1rem;
        line-height: 1.7;
        color: var(--color-text);
        margin-bottom: 24px;
    }
    .exemple-details {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .exemple-item {
        padding: 16px;
        background: var(--color-bg-light);
        border-radius: var(--radius);
        font-size: 0.95rem;
        line-height: 1.6;
    }
    .exemple-item strong {
        color: var(--color-primary-dark);
        display: block;
        margin-bottom: 4px;
    }
    .exemple-item span {
        color: var(--color-text-light);
    }
    .testimonial-highlight {
        max-width: 600px;
        margin: 0 auto;
    }
    .testimonial-featured {
        text-align: center;
        padding: 40px;
    }
    .testimonial-featured .testimonial-author {
        justify-content: center;
    }
    .links-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    .link-card {
        background: var(--color-bg);
        padding: 32px 24px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        text-align: center;
        transition: all var(--transition);
        display: block;
    }
    .link-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }
    .link-icon {
        font-size: 2rem;
        display: block;
        margin-bottom: 12px;
    }
    .link-card h3 {
        font-size: 1.1rem;
        color: var(--color-primary-dark);
        margin-bottom: 8px;
    }
    .link-card p {
        font-size: 0.9rem;
        color: var(--color-text-light);
    }
    @media (max-width: 768px) {
        .landing-hero { padding: 110px 0 40px; }
        .landing-hero h1 { font-size: 2rem; }
        .ages-grid { grid-template-columns: repeat(2, 1fr); }
        .links-grid { grid-template-columns: 1fr; }
        .exemple-content { padding: 24px; }
    }
    @media (max-width: 480px) {
        .ages-grid { grid-template-columns: 1fr; }
    }

    .landing-hero .container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: center;
    }
    .landing-visual {
        display: flex;
        justify-content: center;
    }
    .landing-visual .board-mockup {
        max-width: 380px;
    }
    @media (max-width: 768px) {
        .landing-hero .container {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .landing-visual .board-mockup {
            max-width: 300px;
        }
    }
</style>
