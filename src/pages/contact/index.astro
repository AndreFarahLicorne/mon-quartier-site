---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<Layout
    title="Contactez-nous"
    description="Une question sur nos jeux de plateau personnalisés ? Contactez l'équipe Mon Quartier via notre formulaire. Réponse garantie sous 48h."
>
    <Navbar />
    <main>
        <section class="contact-hero">
            <div class="container">
                <Breadcrumb items={[
                    { label: "Accueil", href: "/" },
                    { label: "Contact" },
                ]} />
                <h1>Contactez-nous</h1>
                <p class="contact-subtitle">Une question, une idée de projet, un partenariat ? Écrivez-nous, on vous répond sous 48h.</p>
            </div>
        </section>

        <section class="section section-light">
            <div class="container contact-layout">
                <div class="contact-form-wrapper">
                    <form id="contactForm" class="contact-form" action="https://api.web3forms.com/submit" method="POST">
                        <input type="hidden" name="access_key" value="079156f8-d186-4ef3-99d5-28c6b1973be9">
                        <input type="hidden" name="subject" value="Nouveau message — Mon Quartier (Contact)">
                        <input type="hidden" name="from_name" value="Formulaire Contact">
                        <input type="hidden" name="redirect" value="https://monquartier-jeu.fr/contact/merci/">
                        <input type="hidden" name="botcheck" value="">

                        <div class="form-grid">
                            <div class="form-group">
                                <label for="nom">Nom complet *</label>
                                <input type="text" id="nom" name="nom" required placeholder="Votre nom" autocomplete="name">
                            </div>
                            <div class="form-group">
                                <label for="email">Email *</label>
                                <input type="email" id="email" name="email" required placeholder="votre@email.com" autocomplete="email">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="sujet">Sujet *</label>
                            <select id="sujet" name="sujet" required>
                                <option value="" disabled selected>Choisissez un sujet</option>
                                <option value="question">Question sur les jeux personnalisés</option>
                                <option value="devis">Demande de devis</option>
                                <option value="commande">Suivi de commande</option>
                                <option value="partenariat">Proposition de partenariat</option>
                                <option value="presse">Presse / Média</option>
                                <option value="autre">Autre</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="message">Votre message *</label>
                            <textarea id="message" name="message" rows="7" placeholder="Décrivez votre demande en quelques lignes..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg btn-submit">Envoyer mon message</button>
                        <p class="form-note">* Champs obligatoires — Réponse garantie sous 48h</p>
                    </form>

                </div>

                <aside class="contact-sidebar">
                    <div class="sidebar-card">
                        <h3>Vous avez un projet précis ?</h3>
                        <p>Si vous souhaitez créer un jeu de plateau personnalisé, utilisez plutôt notre formulaire de devis dédié. Il nous permettra de mieux comprendre votre projet.</p>
                        <a href="/devis/" class="btn btn-outline">Demander un devis</a>
                    </div>

                    <div class="sidebar-card">
                        <h3>Questions fréquentes</h3>
                        <p>Vous trouverez peut-être la réponse à votre question dans notre FAQ sur la page d'accueil.</p>
                        <a href="/#contact" class="btn btn-outline">Voir la FAQ</a>
                    </div>

                    <div class="sidebar-card">
                        <h3>Délai de réponse</h3>
                        <p>Nous répondons à tous les messages sous <strong>48 heures ouvrées</strong>. Pour les demandes urgentes, précisez-le dans votre message.</p>
                    </div>
                </aside>
            </div>
        </section>
    </main>
    <Footer />

</Layout>

<style>
    .contact-hero {
        padding: 140px 0 50px;
        background: linear-gradient(135deg, #f0f7f0 0%, #e8f5e9 100%);
    }
    .contact-hero h1 {
        font-family: var(--font-heading);
        font-size: 2.8rem;
        color: var(--color-primary-dark);
        margin-bottom: 12px;
    }
    .contact-subtitle {
        font-size: 1.15rem;
        color: var(--color-text-light);
        max-width: 550px;
        line-height: 1.7;
    }

    .contact-layout {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 48px;
        align-items: start;
    }

    /* Form */
    .contact-form {
        background: var(--color-bg);
        padding: 40px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
    }
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 20px;
    }
    .form-group label {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--color-text);
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
        font-family: var(--font-body);
        font-size: 1rem;
        padding: 12px 16px;
        border: 2px solid var(--color-border);
        border-radius: var(--radius);
        background: var(--color-bg);
        color: var(--color-text);
        transition: border-color 0.3s ease;
        width: 100%;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--color-primary);
    }
    .form-group textarea {
        resize: vertical;
        min-height: 140px;
    }
    .btn-submit {
        width: 100%;
        padding: 16px;
        font-size: 1.1rem;
    }
    .form-note {
        text-align: center;
        font-size: 0.85rem;
        color: var(--color-text-light);
        margin-top: 16px;
    }
    .form-success {
        text-align: center;
        padding: 60px 40px;
        background: var(--color-bg);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
    }
    .success-icon { font-size: 3rem; margin-bottom: 16px; }
    .form-success h3 { font-size: 1.5rem; color: var(--color-primary-dark); margin-bottom: 8px; }
    .form-success p { color: var(--color-text-light); }

    /* Sidebar */
    .contact-sidebar {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .sidebar-card {
        background: var(--color-bg);
        border-radius: var(--radius-lg);
        padding: 24px;
        border: 1px solid var(--color-border);
    }
    .sidebar-card h3 {
        font-family: var(--font-heading);
        font-size: 1.05rem;
        color: var(--color-primary-dark);
        margin-bottom: 8px;
    }
    .sidebar-card p {
        font-size: 0.9rem;
        color: var(--color-text-light);
        line-height: 1.6;
        margin-bottom: 12px;
    }
    .sidebar-card .btn-outline {
        font-size: 0.85rem;
        padding: 8px 20px;
    }

    @media (max-width: 768px) {
        .contact-hero { padding: 110px 0 40px; }
        .contact-hero h1 { font-size: 2rem; }
        .contact-layout {
            grid-template-columns: 1fr;
            gap: 32px;
        }
        .contact-form { padding: 24px 20px; }
        .form-grid { grid-template-columns: 1fr; }
    }
</style>
