---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout
    title="Demander un devis gratuit"
    description="Décrivez votre projet de jeu de plateau personnalisé et recevez une proposition sur mesure sous 48h. Devis gratuit et sans engagement."
>
    <Navbar />
    <main>
        <section class="devis-hero">
            <div class="container">
                <Breadcrumb items={[
                    { label: "Accueil", href: "/" },
                    { label: "Demander un devis" },
                ]} />
                <h1>Demandez votre devis gratuit</h1>
                <p class="devis-subtitle">Décrivez-nous votre projet et recevez une proposition personnalisée sous 48h. C'est gratuit et sans engagement.</p>
            </div>
        </section>

        <section class="section section-light">
            <div class="container devis-layout">
                <div class="devis-form-wrapper">
                    <form id="devisForm" class="devis-form" action="https://api.web3forms.com/submit" method="POST">
                        <input type="hidden" name="access_key" value="079156f8-d186-4ef3-99d5-28c6b1973be9">
                        <input type="hidden" name="subject" value="Nouvelle demande de devis — Mon Quartier">
                        <input type="checkbox" name="botcheck" style="display:none">

                        <div class="form-grid">
                            <div class="form-group">
                                <label for="nom">Nom complet *</label>
                                <input type="text" id="nom" name="nom" required placeholder="Votre nom" autocomplete="name">
                            </div>
                            <div class="form-group">
                                <label for="email">Email *</label>
                                <input type="email" id="email" name="email" required placeholder="votre@email.com" autocomplete="email">
                            </div>
                            <div class="form-group">
                                <label for="telephone">Téléphone</label>
                                <input type="tel" id="telephone" name="telephone" placeholder="06 12 34 56 78" autocomplete="tel">
                            </div>
                            <div class="form-group">
                                <label for="occasion">Type de projet *</label>
                                <select id="occasion" name="occasion" required>
                                    <option value="" disabled selected>Choisissez une occasion</option>
                                    <option value="quartier">Jeu de quartier / ville</option>
                                    <option value="mariage">Mariage</option>
                                    <option value="anniversaire">Anniversaire</option>
                                    <option value="entreprise">Entreprise / Team building</option>
                                    <option value="association">Association / Comité</option>
                                    <option value="cadeau">Cadeau personnalisé</option>
                                    <option value="autre">Autre</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="quantite">Nombre d'exemplaires souhaités</label>
                                <select id="quantite" name="quantite">
                                    <option value="" disabled selected>Sélectionnez une quantité</option>
                                    <option value="1">1 exemplaire</option>
                                    <option value="2-5">2 à 5 exemplaires</option>
                                    <option value="6-20">6 à 20 exemplaires</option>
                                    <option value="21-50">21 à 50 exemplaires</option>
                                    <option value="51-100">51 à 100 exemplaires</option>
                                    <option value="100+">Plus de 100 exemplaires</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="message">Décrivez votre projet *</label>
                            <textarea id="message" name="message" rows="6" required placeholder="Parlez-nous de votre quartier, de l'occasion, de vos idées de personnalisation..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg btn-submit">Envoyer ma demande de devis</button>
                        <p class="form-note">* Champs obligatoires — Réponse garantie sous 48h</p>
                    </form>

                    <div id="formSuccess" class="form-success" hidden>
                        <div class="success-icon">✅</div>
                        <h3>Demande envoyée !</h3>
                        <p>Merci pour votre demande. Nous vous répondrons sous 48h avec une proposition personnalisée.</p>
                    </div>
                </div>

                <aside class="devis-sidebar">
                    <div class="sidebar-card">
                        <div class="sidebar-icon">🎯</div>
                        <h3>Comment ça marche ?</h3>
                        <ol class="sidebar-steps">
                            <li>Vous remplissez ce formulaire</li>
                            <li>On vous recontacte sous 48h</li>
                            <li>On crée la maquette ensemble</li>
                            <li>Vous validez, on fabrique, on livre</li>
                        </ol>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-icon">💬</div>
                        <h3>Une question ?</h3>
                        <p>Vous préférez nous écrire directement ? Utilisez notre formulaire de contact.</p>
                        <a href="/contact/" class="btn btn-outline btn-sm">Page contact</a>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-icon">⭐</div>
                        <h3>Ce qu'en disent nos clients</h3>
                        <p class="sidebar-quote">"On a offert le jeu à mon père pour ses 60 ans. Il était ému aux larmes !"</p>
                        <span class="sidebar-author">— Sophie L.</span>
                    </div>
                </aside>
            </div>
        </section>
    </main>
    <Footer />

    <script>
        const form = document.getElementById('devisForm') as HTMLFormElement | null;
        const success = document.getElementById('formSuccess');
        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
            btn.textContent = 'Envoi en cours...';
            btn.disabled = true;
            try {
                const res = await fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    body: new FormData(form),
                });
                if (res.ok) {
                    form.hidden = true;
                    if (success) success.hidden = false;
                    success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } else {
                    btn.textContent = 'Erreur, veuillez réessayer';
                    btn.disabled = false;
                }
            } catch {
                btn.textContent = 'Erreur, veuillez réessayer';
                btn.disabled = false;
            }
        });
    </script>
</Layout>

<style>
    .devis-hero {
        padding: 140px 0 50px;
        background: linear-gradient(135deg, #e8f5e9 0%, #f0f7f0 100%);
    }
    .devis-hero h1 {
        font-family: var(--font-heading);
        font-size: 2.8rem;
        color: var(--color-primary-dark);
        margin-bottom: 12px;
    }
    .devis-subtitle {
        font-size: 1.15rem;
        color: var(--color-text-light);
        max-width: 550px;
        line-height: 1.7;
    }

    .devis-layout {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 48px;
        align-items: start;
    }

    .devis-form {
        background: var(--color-bg);
        padding: 40px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
    }
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 20px;
    }
    .form-group label {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--color-text);
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
        font-family: var(--font-body);
        font-size: 1rem;
        padding: 12px 16px;
        border: 2px solid var(--color-border);
        border-radius: var(--radius);
        background: var(--color-bg);
        color: var(--color-text);
        transition: border-color 0.3s ease;
        width: 100%;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--color-primary);
    }
    .form-group textarea {
        resize: vertical;
        min-height: 140px;
    }
    .btn-submit {
        width: 100%;
        padding: 16px;
        font-size: 1.1rem;
    }
    .form-note {
        text-align: center;
        font-size: 0.85rem;
        color: var(--color-text-light);
        margin-top: 16px;
    }
    .form-success {
        text-align: center;
        padding: 60px 40px;
        background: var(--color-bg);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
    }
    .success-icon { font-size: 3rem; margin-bottom: 16px; }
    .form-success h3 { font-size: 1.5rem; color: var(--color-primary-dark); margin-bottom: 8px; }
    .form-success p { color: var(--color-text-light); }

    /* Sidebar */
    .devis-sidebar {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .sidebar-card {
        background: var(--color-bg);
        border-radius: var(--radius-lg);
        padding: 24px;
        border: 1px solid var(--color-border);
    }
    .sidebar-icon {
        font-size: 1.5rem;
        margin-bottom: 8px;
    }
    .sidebar-card h3 {
        font-family: var(--font-heading);
        font-size: 1.05rem;
        color: var(--color-primary-dark);
        margin-bottom: 10px;
    }
    .sidebar-card p {
        font-size: 0.9rem;
        color: var(--color-text-light);
        line-height: 1.6;
        margin-bottom: 12px;
    }
    .sidebar-steps {
        margin: 0 0 0 18px;
        font-size: 0.9rem;
        color: var(--color-text-light);
        line-height: 1.8;
    }
    .sidebar-steps li {
        margin-bottom: 4px;
    }
    .sidebar-quote {
        font-style: italic;
    }
    .sidebar-author {
        font-size: 0.85rem;
        color: var(--color-text-light);
        font-weight: 600;
    }
    .btn-sm {
        font-size: 0.85rem;
        padding: 8px 20px;
    }

    @media (max-width: 768px) {
        .devis-hero { padding: 110px 0 40px; }
        .devis-hero h1 { font-size: 2rem; }
        .devis-layout {
            grid-template-columns: 1fr;
            gap: 32px;
        }
        .devis-form { padding: 24px 20px; }
        .form-grid { grid-template-columns: 1fr; }
    }
</style>
