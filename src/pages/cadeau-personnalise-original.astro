---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import BoardMockup from '../components/BoardMockup.astro';

const title = "Cadeau original — Un jeu de société unique";
const description = "À court d'idées cadeaux ? Offrez un jeu de plateau personnalisé avec les lieux et souvenirs qui comptent.";
---

<Layout title={title} description={description}>
    <Navbar />
    <main>
        <section class="landing-hero">
            <div class="container">
                <div class="landing-hero-text">
                <Breadcrumb items={[
                    { label: "Accueil", href: "/" },
                    { label: "Cadeau personnalisé original" }
                ]} />
                <h1>Le cadeau personnalisé qui sort vraiment de l'ordinaire</h1>
                <p class="landing-subtitle">Fini les cadeaux banals ! Offrez un jeu de plateau unique, créé sur mesure avec les lieux et souvenirs qui comptent pour la personne que vous aimez.</p>
                <a href="#devis" class="btn btn-primary btn-lg">Demander un devis gratuit</a>
                </div><!-- /landing-hero-text -->
                <div class="landing-visual">
                    <BoardMockup />
                </div>
            </div>
        </section>

        <!-- Pourquoi un jeu comme cadeau -->
        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2>Pourquoi un jeu de plateau est le cadeau parfait ?</h2>
                    <p>Un cadeau qui a du sens, qui crée du lien et qui dure dans le temps.</p>
                </div>
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon">🎯</div>
                        <h3>100% personnalisé</h3>
                        <p>Pas un cadeau générique. Chaque case, chaque rue, chaque détail est pensé pour la personne qui le reçoit. Un objet unique au monde, à son image.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">❤️</div>
                        <h3>Chargé d'émotion</h3>
                        <p>Les lieux qui comptent deviennent des cases de jeu. Le destinataire redécouvre ses souvenirs, ses lieux préférés, les moments qui ont marqué sa vie.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">👨‍👩‍👧‍👦</div>
                        <h3>Un moment de partage</h3>
                        <p>Contrairement à un objet déco, un jeu se partage. Famille et amis se réunissent autour du plateau pour des parties mémorables, encore et encore.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Toutes les occasions -->
        <section class="section section-cream">
            <div class="container">
                <div class="section-header">
                    <h2>Un cadeau pour toutes les occasions</h2>
                    <p>Quelle que soit la fête, un jeu personnalisé fait toujours mouche.</p>
                </div>
                <div class="occasions-grid">
                    <div class="occasion-card">
                        <span class="occasion-icon">🎄</span>
                        <h3>Noël</h3>
                        <p>Le cadeau au pied du sapin qui fera l'unanimité. Toute la famille pourra jouer pendant les fêtes.</p>
                    </div>
                    <div class="occasion-card">
                        <span class="occasion-icon">👨</span>
                        <h3>Fête des pères</h3>
                        <p>Bien mieux qu'une cravate ! Un jeu avec les lieux qui ont marqué la vie de papa.</p>
                    </div>
                    <div class="occasion-card">
                        <span class="occasion-icon">👩</span>
                        <h3>Fête des mères</h3>
                        <p>Un cadeau original et touchant. Maman découvrira ses souvenirs case après case.</p>
                    </div>
                    <div class="occasion-card">
                        <span class="occasion-icon">🏠</span>
                        <h3>Crémaillère</h3>
                        <p>Offrez le quartier en jeu ! Le cadeau parfait pour découvrir son nouveau voisinage.</p>
                    </div>
                    <div class="occasion-card">
                        <span class="occasion-icon">🎉</span>
                        <h3>Départ en retraite</h3>
                        <p>Résumez une carrière en un plateau. Les collègues, les bureaux, les anecdotes du quotidien.</p>
                    </div>
                    <div class="occasion-card">
                        <span class="occasion-icon">🎂</span>
                        <h3>Anniversaire</h3>
                        <p>Un jeu qui retrace une vie entière. Le cadeau d'anniversaire dont on se souvient.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Exemples variés -->
        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2>Des exemples qui inspirent</h2>
                    <p>Chaque jeu est unique. Voici quelques créations qui ont marqué les esprits.</p>
                </div>
                <div class="exemples-grid">
                    <div class="exemple-mini">
                        <div class="exemple-mini-header">
                            <span class="exemple-mini-icon">🎄</span>
                            <h3>Noël en famille — Les Martin</h3>
                        </div>
                        <p>Un jeu avec les lieux de vacances de la famille sur 30 ans : la maison de Bretagne, le camping du Var, le chalet de montagne... 15 exemplaires offerts à chaque membre de la famille.</p>
                    </div>
                    <div class="exemple-mini">
                        <div class="exemple-mini-header">
                            <span class="exemple-mini-icon">🎉</span>
                            <h3>Départ en retraite — Gérard</h3>
                        </div>
                        <p>Après 35 ans dans la même entreprise, les collègues de Gérard lui ont offert un plateau avec les bureaux, la cantine, le parking et tous les lieux qui ont marqué sa carrière.</p>
                    </div>
                    <div class="exemple-mini">
                        <div class="exemple-mini-header">
                            <span class="exemple-mini-icon">🏠</span>
                            <h3>Crémaillère — Léa & Hugo</h3>
                        </div>
                        <p>Pour leur crémaillère à Bordeaux, leurs amis ont commandé un jeu avec les lieux emblématiques du quartier Saint-Michel : le marché, les quais, les bars à vin...</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Témoignage -->
        <section class="section section-dark">
            <div class="container">
                <div class="section-header">
                    <h2>Ce qu'en disent nos clients</h2>
                </div>
                <div class="testimonials-grid testimonials-double">
                    <article class="testimonial-card">
                        <div class="testimonial-stars" aria-label="5 étoiles sur 5">★★★★★</div>
                        <p class="testimonial-text">"On a offert le jeu à mon père pour ses 60 ans. Il était ému aux larmes ! Chaque case lui rappelait un souvenir. Le plus beau cadeau qu'on ait pu lui faire."</p>
                        <div class="testimonial-author">
                            <div class="testimonial-avatar">S</div>
                            <div>
                                <strong>Sophie L.</strong>
                                <span>Cadeau anniversaire</span>
                            </div>
                        </div>
                    </article>
                    <article class="testimonial-card">
                        <div class="testimonial-stars" aria-label="5 étoiles sur 5">★★★★★</div>
                        <p class="testimonial-text">"Nos invités de mariage ont adoré ! C'était l'animation phare de la soirée. Le plateau retrace notre histoire et c'est devenu un objet déco dans notre salon."</p>
                        <div class="testimonial-author">
                            <div class="testimonial-avatar">J</div>
                            <div>
                                <strong>Julie & Thomas M.</strong>
                                <span>Cadeau de mariage</span>
                            </div>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <!-- Comment ça marche -->
        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2>Comment créer votre cadeau personnalisé ?</h2>
                    <p>Un processus simple en 3 étapes pour un résultat qui émerveille.</p>
                </div>
                <div class="steps-container">
                    <div class="step">
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <h3>Racontez-nous l'histoire</h3>
                            <p>Partagez les lieux, les souvenirs et les anecdotes de la personne à qui vous destinez le jeu. Plus c'est personnel, plus le cadeau sera touchant.</p>
                        </div>
                    </div>
                    <div class="step">
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <h3>Validez la maquette</h3>
                            <p>Notre équipe transforme vos souvenirs en un plateau de jeu unique. Vous vérifiez chaque détail et apportez vos ajustements avant la fabrication.</p>
                        </div>
                    </div>
                    <div class="step">
                        <div class="step-number">3</div>
                        <div class="step-content">
                            <h3>Offrez la surprise</h3>
                            <p>Recevez votre jeu sous 3 à 4 semaines, joliment emballé et prêt à offrir. L'émotion au déballage est garantie !</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Maillage interne -->
        <section class="section section-cream">
            <div class="container">
                <div class="section-header">
                    <h2>Explorez nos créations par occasion</h2>
                    <p>Chaque événement mérite un jeu sur mesure.</p>
                </div>
                <div class="links-grid links-grid-4">
                    <a href="/jeu-personnalise-mariage/" class="link-card">
                        <span class="link-icon">💍</span>
                        <h3>Mariage</h3>
                        <p>Votre histoire d'amour en jeu de société.</p>
                    </a>
                    <a href="/jeu-personnalise-anniversaire/" class="link-card">
                        <span class="link-icon">🎂</span>
                        <h3>Anniversaire</h3>
                        <p>Les lieux marquants d'une vie sur un plateau.</p>
                    </a>
                    <a href="/jeu-personnalise-entreprise/" class="link-card">
                        <span class="link-icon">🏢</span>
                        <h3>Entreprise</h3>
                        <p>Team building et cohésion d'équipe.</p>
                    </a>
                    <a href="/jeu-de-quartier-personnalise/" class="link-card">
                        <span class="link-icon">🏘️</span>
                        <h3>Quartier</h3>
                        <p>Votre quartier transformé en jeu de société.</p>
                    </a>
                </div>
                <div class="back-home">
                    <a href="/" class="btn btn-outline">Retour à l'accueil</a>
                </div>
            </div>
        </section>

        <!-- Formulaire de devis -->
        <section class="section section-cream" id="devis">
            <div class="container">
                <div class="section-header">
                    <h2>Demandez votre devis gratuit</h2>
                    <p>Décrivez-nous votre idée cadeau et recevez une proposition personnalisée sous 48h.</p>
                </div>
                <div class="form-container">
                    <form id="devisForm" class="devis-form" aria-label="Formulaire de demande de devis" action="https://api.web3forms.com/submit" method="POST">
                        <input type="hidden" name="access_key" value="079156f8-d186-4ef3-99d5-28c6b1973be9">
                        <input type="hidden" name="subject" value="Nouvelle demande de devis — Cadeau personnalisé">
                        <input type="hidden" name="redirect" value="https://monquartier-jeu.fr/cadeau-personnalise-original/#devis">
                        <input type="checkbox" name="botcheck" class="hidden" style="display:none">
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="nom">Nom complet *</label>
                                <input type="text" id="nom" name="nom" required placeholder="Votre nom" autocomplete="name">
                            </div>
                            <div class="form-group">
                                <label for="email">Email *</label>
                                <input type="email" id="email" name="email" required placeholder="votre@email.com" autocomplete="email">
                            </div>
                            <div class="form-group">
                                <label for="telephone">Téléphone</label>
                                <input type="tel" id="telephone" name="telephone" placeholder="06 12 34 56 78" autocomplete="tel">
                            </div>
                            <div class="form-group">
                                <label for="occasion">Type de projet *</label>
                                <select id="occasion" name="occasion" required>
                                    <option value="" disabled>Choisissez une occasion</option>
                                    <option value="quartier">Jeu de quartier / ville</option>
                                    <option value="mariage">Mariage</option>
                                    <option value="anniversaire">Anniversaire</option>
                                    <option value="entreprise">Entreprise / Team building</option>
                                    <option value="association">Association / Comité</option>
                                    <option value="cadeau" selected>Cadeau personnalisé</option>
                                    <option value="autre">Autre</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="quantite">Nombre d'exemplaires souhaités</label>
                                <select id="quantite" name="quantite">
                                    <option value="" disabled selected>Sélectionnez une quantité</option>
                                    <option value="1">1 exemplaire</option>
                                    <option value="2-5">2 à 5 exemplaires</option>
                                    <option value="6-20">6 à 20 exemplaires</option>
                                    <option value="21-50">21 à 50 exemplaires</option>
                                    <option value="51-100">51 à 100 exemplaires</option>
                                    <option value="100+">Plus de 100 exemplaires</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group form-group-full">
                            <label for="message">Décrivez votre projet *</label>
                            <textarea id="message" name="message" rows="5" required placeholder="Parlez-nous de l'occasion, de la personne à qui vous offrez le jeu, des lieux et souvenirs à inclure..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg btn-submit">Envoyer ma demande de devis</button>
                        <p class="form-note">* Champs obligatoires — Réponse garantie sous 48h</p>
                    </form>
                    <div id="formSuccess" class="form-success" hidden>
                        <div class="success-icon">✅</div>
                        <h3>Demande envoyée !</h3>
                        <p>Merci pour votre demande. Nous vous répondrons sous 48h avec une proposition personnalisée.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />

    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "Cadeau personnalisé original — Jeu de plateau sur mesure",
        "description": description,
        "provider": {
            "@type": "LocalBusiness",
            "name": "Mon Quartier",
            "url": "https://monquartier-jeu.fr"
        },
        "areaServed": {
            "@type": "Country",
            "name": "France"
        },
        "serviceType": "Création de jeu de plateau personnalisé — Cadeau original"
    })} />
</Layout>

<style>
    .landing-hero {
        padding: 140px 0 80px;
        background: linear-gradient(135deg, #fef0f5 0%, #faf6f1 50%, #f0f7f0 100%);
    }
    .landing-hero .container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
    }
    .landing-hero-text {
        /* wrapper for text content */
    }
    .landing-hero h1 {
        font-family: var(--font-heading);
        font-size: 2.6rem;
        color: var(--color-primary-dark);
        margin-bottom: 16px;
        line-height: 1.15;
    }
    .landing-subtitle {
        font-size: 1.1rem;
        color: var(--color-text-light);
        line-height: 1.7;
        margin-bottom: 28px;
    }
    .landing-visual {
        display: flex;
        justify-content: center;
        align-items: center;
    }
    .landing-visual :global(.board-mockup) {
        max-width: 400px;
        width: 100%;
    }
    .occasions-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    .occasion-card {
        background: var(--color-bg);
        padding: 28px 24px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        text-align: center;
        transition: all var(--transition);
    }
    .occasion-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }
    .occasion-icon {
        font-size: 2.2rem;
        display: block;
        margin-bottom: 12px;
    }
    .occasion-card h3 {
        font-size: 1.1rem;
        color: var(--color-primary-dark);
        margin-bottom: 8px;
    }
    .occasion-card p {
        font-size: 0.9rem;
        color: var(--color-text-light);
        line-height: 1.6;
    }
    .exemples-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    .exemple-mini {
        background: var(--color-bg);
        padding: 28px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        transition: all var(--transition);
    }
    .exemple-mini:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }
    .exemple-mini-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }
    .exemple-mini-icon {
        font-size: 1.8rem;
    }
    .exemple-mini h3 {
        font-size: 1.05rem;
        color: var(--color-primary-dark);
    }
    .exemple-mini p {
        font-size: 0.9rem;
        color: var(--color-text-light);
        line-height: 1.6;
    }
    .testimonials-double {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px;
        max-width: 900px;
        margin: 0 auto;
    }
    .links-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    .links-grid-4 {
        grid-template-columns: repeat(4, 1fr);
    }
    .link-card {
        background: var(--color-bg);
        padding: 32px 24px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        text-align: center;
        transition: all var(--transition);
        display: block;
    }
    .link-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }
    .link-icon {
        font-size: 2rem;
        display: block;
        margin-bottom: 12px;
    }
    .link-card h3 {
        font-size: 1.1rem;
        color: var(--color-primary-dark);
        margin-bottom: 8px;
    }
    .link-card p {
        font-size: 0.9rem;
        color: var(--color-text-light);
    }
    .back-home {
        text-align: center;
        margin-top: 32px;
    }
    @media (max-width: 1024px) {
        .links-grid-4 { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
        .landing-hero { padding: 110px 0 50px; }
        .landing-hero .container {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .landing-hero h1 { font-size: 2rem; }
        .landing-visual :global(.board-mockup) { max-width: 300px; margin: 0 auto; }
        .occasions-grid { grid-template-columns: 1fr; }
        .exemples-grid { grid-template-columns: 1fr; }
        .testimonials-double { grid-template-columns: 1fr; }
        .links-grid { grid-template-columns: 1fr; }
        .links-grid-4 { grid-template-columns: 1fr; }
    }

</style>
