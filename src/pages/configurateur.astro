---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const cases = [
    { num: 1, side: "bottom", type: "corner", name: "DÉPART", group: null, price: null },
    { num: 2, side: "bottom", type: "terrain", name: "Bd de Belleville", group: "brown", price: 60 },
    { num: 3, side: "bottom", type: "communaute", name: "Communauté", group: null, price: null },
    { num: 4, side: "bottom", type: "terrain", name: "Rue Lecourbe", group: "brown", price: 60 },
    { num: 5, side: "bottom", type: "taxe", name: "Impôts", group: null, price: 200 },
    { num: 6, side: "bottom", type: "gare", name: "Gare Montparnasse", group: "gare", price: 200 },
    { num: 7, side: "bottom", type: "terrain", name: "Rue de Vaugirard", group: "lightblue", price: 100 },
    { num: 8, side: "bottom", type: "chance", name: "Chance", group: null, price: null },
    { num: 9, side: "bottom", type: "terrain", name: "Rue de Courcelles", group: "lightblue", price: 100 },
    { num: 10, side: "bottom", type: "terrain", name: "Av. de la République", group: "lightblue", price: 120 },
    { num: 11, side: "left", type: "corner", name: "PRISON", group: null, price: null },
    { num: 12, side: "left", type: "terrain", name: "Bd de la Villette", group: "pink", price: 140 },
    { num: 13, side: "left", type: "compagnie", name: "Cie d'électricité", group: "compagnie", price: 150 },
    { num: 14, side: "left", type: "terrain", name: "Av. de Neuilly", group: "pink", price: 140 },
    { num: 15, side: "left", type: "terrain", name: "Rue du Paradis", group: "pink", price: 160 },
    { num: 16, side: "left", type: "gare", name: "Gare de Lyon", group: "gare", price: 200 },
    { num: 17, side: "left", type: "terrain", name: "Avenue Mozart", group: "orange", price: 180 },
    { num: 18, side: "left", type: "communaute", name: "Communauté", group: null, price: null },
    { num: 19, side: "left", type: "terrain", name: "Bd Saint-Michel", group: "orange", price: 180 },
    { num: 20, side: "left", type: "terrain", name: "Place Pigalle", group: "orange", price: 200 },
    { num: 21, side: "top", type: "corner", name: "PARKING GRATUIT", group: null, price: null },
    { num: 22, side: "top", type: "terrain", name: "Av. Matignon", group: "red", price: 220 },
    { num: 23, side: "top", type: "chance", name: "Chance", group: null, price: null },
    { num: 24, side: "top", type: "terrain", name: "Bd Malesherbes", group: "red", price: 220 },
    { num: 25, side: "top", type: "terrain", name: "Av. Henri-Martin", group: "red", price: 240 },
    { num: 26, side: "top", type: "gare", name: "Gare du Nord", group: "gare", price: 200 },
    { num: 27, side: "top", type: "terrain", name: "Fg Saint-Honoré", group: "yellow", price: 260 },
    { num: 28, side: "top", type: "terrain", name: "Place de la Bourse", group: "yellow", price: 260 },
    { num: 29, side: "top", type: "compagnie", name: "Cie des eaux", group: "compagnie", price: 150 },
    { num: 30, side: "top", type: "terrain", name: "Rue La Fayette", group: "yellow", price: 280 },
    { num: 31, side: "right", type: "corner", name: "ALLEZ EN PRISON", group: null, price: null },
    { num: 32, side: "right", type: "terrain", name: "Av. de Breteuil", group: "green", price: 300 },
    { num: 33, side: "right", type: "terrain", name: "Avenue Foch", group: "green", price: 300 },
    { num: 34, side: "right", type: "communaute", name: "Communauté", group: null, price: null },
    { num: 35, side: "right", type: "terrain", name: "Bd des Capucines", group: "green", price: 320 },
    { num: 36, side: "right", type: "gare", name: "Gare Saint-Lazare", group: "gare", price: 200 },
    { num: 37, side: "right", type: "chance", name: "Chance", group: null, price: null },
    { num: 38, side: "right", type: "terrain", name: "Av. Champs-Élysées", group: "darkblue", price: 350 },
    { num: 39, side: "right", type: "taxe", name: "Taxe de luxe", group: null, price: 100 },
    { num: 40, side: "right", type: "terrain", name: "Rue de la Paix", group: "darkblue", price: 400 },
];

const groupColors: Record<string, string> = {
    brown: "#8B4513", lightblue: "#87CEEB", pink: "#D81B60", orange: "#F57C00",
    red: "#D32F2F", yellow: "#FDD835", green: "#388E3C", darkblue: "#0D47A1",
    gare: "#333333", compagnie: "#78909C",
};

const bottomCells = cases.filter(c => c.side === "bottom" && c.type !== "corner").reverse();
const leftCells = cases.filter(c => c.side === "left" && c.type !== "corner");
const topCells = cases.filter(c => c.side === "top" && c.type !== "corner");
const rightCells = cases.filter(c => c.side === "right" && c.type !== "corner");

const cornerCases = cases.filter(c => c.type === "corner");
---

<Layout
    title="Configurateur de jeu de plateau"
    description="Configurez votre propre jeu de plateau personnalisé. Remplacez les noms des rues par ceux de votre quartier directement sur le plateau."
>
    <Navbar />
    <main>
        <section class="config-hero">
            <div class="container">
                <h1>Configurez votre plateau</h1>
                <p class="config-subtitle">Cliquez sur n'importe quelle case pour la personnaliser.</p>
            </div>
        </section>

        <section class="config-section">
            <div class="container">
                <div class="board-wrapper">
                    <div class="board">
                        <!-- Centre -->
                        <div class="board-center">
                            <input type="text" class="center-title" value="MON QUARTIER" maxlength="20" aria-label="Titre du jeu">
                            <span class="center-sub">LE JEU</span>
                        </div>

                        <!-- Coins -->
                        <div class="cell corner corner-bl">
                            <input type="text" class="corner-input" value="DÉPART" maxlength="15" aria-label="Case Départ">
                        </div>
                        <div class="cell corner corner-tl">
                            <input type="text" class="corner-input" value="PARKING GRATUIT" maxlength="20" aria-label="Case Parking Gratuit">
                        </div>
                        <div class="cell corner corner-tr">
                            <input type="text" class="corner-input" value="ALLEZ EN PRISON" maxlength="20" aria-label="Case Allez en Prison">
                        </div>
                        <div class="cell corner corner-br">
                            <input type="text" class="corner-input" value="PRISON" maxlength="15" aria-label="Case Prison">
                        </div>

                        <!-- Bottom row -->
                        {bottomCells.map((c, i) => (
                            <div class={`cell cell-bottom cell-b${i + 1}`} data-num={c.num} data-type={c.type}>
                                {c.group && <div class="color-band band-top" style={`background: ${groupColors[c.group]};`}></div>}
                                <div class="cell-content">
                                    <input type="text" class="cell-input" value={c.name} maxlength="25" aria-label={`Case ${c.num}`}>
                                    {c.price && <span class="cell-price">{c.price} €</span>}
                                </div>
                            </div>
                        ))}

                        <!-- Left column -->
                        {leftCells.map((c, i) => (
                            <div class={`cell cell-left cell-l${i + 1}`} data-num={c.num} data-type={c.type}>
                                {c.group && <div class="color-band band-right" style={`background: ${groupColors[c.group]};`}></div>}
                                <div class="cell-content">
                                    <input type="text" class="cell-input" value={c.name} maxlength="25" aria-label={`Case ${c.num}`}>
                                    {c.price && <span class="cell-price">{c.price} €</span>}
                                </div>
                            </div>
                        ))}

                        <!-- Top row -->
                        {topCells.map((c, i) => (
                            <div class={`cell cell-top cell-t${i + 1}`} data-num={c.num} data-type={c.type}>
                                {c.group && <div class="color-band band-bottom" style={`background: ${groupColors[c.group]};`}></div>}
                                <div class="cell-content">
                                    <input type="text" class="cell-input" value={c.name} maxlength="25" aria-label={`Case ${c.num}`}>
                                    {c.price && <span class="cell-price">{c.price} €</span>}
                                </div>
                            </div>
                        ))}

                        <!-- Right column -->
                        {rightCells.map((c, i) => (
                            <div class={`cell cell-right cell-r${i + 1}`} data-num={c.num} data-type={c.type}>
                                {c.group && <div class="color-band band-left" style={`background: ${groupColors[c.group]};`}></div>}
                                <div class="cell-content">
                                    <input type="text" class="cell-input" value={c.name} maxlength="25" aria-label={`Case ${c.num}`}>
                                    {c.price && <span class="cell-price">{c.price} €</span>}
                                </div>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Légende -->
                <div class="legend">
                    <h3>Groupes de couleurs</h3>
                    <div class="legend-items">
                        <div class="legend-item"><span class="legend-color" style="background: #8B4513;"></span>Marron (60 €)</div>
                        <div class="legend-item"><span class="legend-color" style="background: #87CEEB;"></span>Bleu clair (100-120 €)</div>
                        <div class="legend-item"><span class="legend-color" style="background: #D81B60;"></span>Rose (140-160 €)</div>
                        <div class="legend-item"><span class="legend-color" style="background: #F57C00;"></span>Orange (180-200 €)</div>
                        <div class="legend-item"><span class="legend-color" style="background: #D32F2F;"></span>Rouge (220-240 €)</div>
                        <div class="legend-item"><span class="legend-color" style="background: #FDD835;"></span>Jaune (260-280 €)</div>
                        <div class="legend-item"><span class="legend-color" style="background: #388E3C;"></span>Vert (300-320 €)</div>
                        <div class="legend-item"><span class="legend-color" style="background: #0D47A1;"></span>Bleu foncé (350-400 €)</div>
                        <div class="legend-item"><span class="legend-color" style="background: #333;"></span>Gares (200 €)</div>
                        <div class="legend-item"><span class="legend-color" style="background: #78909C;"></span>Compagnies (150 €)</div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Cartes Chance -->
        <section class="section section-light" id="cartes-chance">
            <div class="container">
                <div class="section-header">
                    <h2>Cartes Chance</h2>
                    <p>Personnalisez les 16 cartes Chance. Glissez-y des anecdotes, des défis ou des private jokes.</p>
                </div>
                <div class="cards-grid">
                    <div class="card-edit chance-card">
                        <span class="card-number">1</span>
                        <input type="text" class="card-input" value="Avancez jusqu'à la case Départ" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">2</span>
                        <input type="text" class="card-input" value="Avancez jusqu'aux Champs-Élysées" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">3</span>
                        <input type="text" class="card-input" value="Avancez jusqu'à la Rue de la Paix" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">4</span>
                        <input type="text" class="card-input" value="Avancez jusqu'à la gare la plus proche" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">5</span>
                        <input type="text" class="card-input" value="Avancez jusqu'à la gare la plus proche" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">6</span>
                        <input type="text" class="card-input" value="Avancez au Boulevard de la Villette" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">7</span>
                        <input type="text" class="card-input" value="Reculez de 3 cases" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">8</span>
                        <input type="text" class="card-input" value="Allez en prison" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">9</span>
                        <input type="text" class="card-input" value="La banque vous verse 50 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">10</span>
                        <input type="text" class="card-input" value="La banque vous verse 150 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">11</span>
                        <input type="text" class="card-input" value="Vous êtes imposé : payez 15 €" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">12</span>
                        <input type="text" class="card-input" value="Amende pour excès de vitesse : 15 €" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">13</span>
                        <input type="text" class="card-input" value="Payez pour frais de scolarité : 150 €" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">14</span>
                        <input type="text" class="card-input" value="Réparations : 25 € par maison, 100 € par hôtel" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">15</span>
                        <input type="text" class="card-input" value="Réparations : 40 € par maison, 115 € par hôtel" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit chance-card">
                        <span class="card-number">16</span>
                        <input type="text" class="card-input" value="Vous êtes libéré de prison (à conserver)" maxlength="80">
                        <span class="card-type">Spéciale</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Cartes Caisse de communauté -->
        <section class="section section-cream" id="cartes-communaute">
            <div class="container">
                <div class="section-header">
                    <h2>Cartes Caisse de communauté</h2>
                    <p>Personnalisez les 16 cartes Communauté. Ajoutez des situations du quotidien de votre quartier.</p>
                </div>
                <div class="cards-grid">
                    <div class="card-edit community-card">
                        <span class="card-number">1</span>
                        <input type="text" class="card-input" value="Avancez jusqu'à la case Départ" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">2</span>
                        <input type="text" class="card-input" value="Allez en prison" maxlength="80">
                        <span class="card-type">Déplacement</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">3</span>
                        <input type="text" class="card-input" value="Erreur de la banque en votre faveur : 200 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">4</span>
                        <input type="text" class="card-input" value="La vente de votre stock vous rapporte 50 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">5</span>
                        <input type="text" class="card-input" value="Vous avez gagné le 2e prix de beauté : 10 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">6</span>
                        <input type="text" class="card-input" value="Héritage : recevez 100 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">7</span>
                        <input type="text" class="card-input" value="Les contributions vous remboursent 20 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">8</span>
                        <input type="text" class="card-input" value="Recevez votre intérêt : 25 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">9</span>
                        <input type="text" class="card-input" value="C'est votre anniversaire : chaque joueur vous donne 10 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">10</span>
                        <input type="text" class="card-input" value="Assurance vie : recevez 100 €" maxlength="80">
                        <span class="card-type">Gain</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">11</span>
                        <input type="text" class="card-input" value="Payez la note du médecin : 50 €" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">12</span>
                        <input type="text" class="card-input" value="Payez l'hôpital : 100 €" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">13</span>
                        <input type="text" class="card-input" value="Payez une amende de 10 €" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">14</span>
                        <input type="text" class="card-input" value="Payez vos frais de scolarité : 50 €" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">15</span>
                        <input type="text" class="card-input" value="Réparations : 40 € par maison, 115 € par hôtel" maxlength="80">
                        <span class="card-type">Paiement</span>
                    </div>
                    <div class="card-edit community-card">
                        <span class="card-number">16</span>
                        <input type="text" class="card-input" value="Vous êtes libéré de prison (à conserver)" maxlength="80">
                        <span class="card-type">Spéciale</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Actions finales -->
        <section class="section section-light">
            <div class="container">
                <div class="config-actions">
                    <button id="resetBtn" class="btn btn-outline">Tout réinitialiser</button>
                    <a href="/devis/" class="btn btn-primary btn-lg">Demander un devis avec cette configuration</a>
                </div>
            </div>
        </section>
    </main>
    <Footer />

    <script>
        // Reset all inputs
        document.getElementById('resetBtn')?.addEventListener('click', () => {
            document.querySelectorAll<HTMLInputElement>('.cell-input, .corner-input, .center-title, .card-input').forEach(el => {
                el.value = el.defaultValue;
            });
        });

        // Focus: select all + highlight
        document.querySelectorAll<HTMLInputElement>('.cell-input, .corner-input, .center-title').forEach(input => {
            input.addEventListener('focus', () => {
                input.select();
                input.closest('.cell, .board-center')?.classList.add('editing');
            });
            input.addEventListener('blur', () => {
                input.closest('.cell, .board-center')?.classList.remove('editing');
            });
        });

        // Card inputs: select on focus
        document.querySelectorAll<HTMLInputElement>('.card-input').forEach(input => {
            input.addEventListener('focus', () => {
                input.select();
                input.closest('.card-edit')?.classList.add('editing');
            });
            input.addEventListener('blur', () => {
                input.closest('.card-edit')?.classList.remove('editing');
            });
        });
    </script>
</Layout>

<style>
    .config-hero {
        padding: 140px 0 40px;
        background: linear-gradient(135deg, #e8f5e9 0%, #f0f7f0 100%);
        text-align: center;
    }
    .config-hero h1 {
        font-family: var(--font-heading);
        font-size: 2.5rem;
        color: var(--color-primary-dark);
        margin-bottom: 12px;
    }
    .config-subtitle {
        font-size: 1.1rem;
        color: var(--color-text-light);
    }
    .config-section {
        padding: 40px 0 80px;
    }

    /* Board */
    .board-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 32px;
        overflow-x: auto;
        padding: 16px;
    }
    .board {
        width: 760px;
        height: 760px;
        min-width: 760px;
        background: #c8e6c0;
        border: 3px solid #1a1a1a;
        border-radius: 6px;
        display: grid;
        grid-template-columns: 1.5fr repeat(9, 1fr) 1.5fr;
        grid-template-rows: 1.5fr repeat(9, 1fr) 1.5fr;
        box-shadow: 0 8px 32px rgba(0,0,0,0.15);
    }

    /* Centre */
    .board-center {
        grid-column: 2 / 11;
        grid-row: 2 / 11;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
    }
    .center-title {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a1a1a;
        text-align: center;
        background: transparent;
        border: 2px dashed transparent;
        border-radius: 8px;
        padding: 8px 16px;
        width: 220px;
        letter-spacing: 1px;
        transition: all 0.2s;
    }
    .center-title:hover { border-color: rgba(0,0,0,0.2); }
    .center-title:focus { outline: none; border-color: var(--color-primary); background: rgba(255,255,255,0.8); }
    .center-sub {
        font-family: var(--font-heading);
        font-size: 0.7rem;
        color: #c0392b;
        letter-spacing: 3px;
    }

    /* Corners */
    .corner {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #b8d4a8;
        border: 1px solid rgba(0,0,0,0.15);
    }
    .corner-input {
        font-family: var(--font-heading);
        font-size: 0.45rem;
        font-weight: 700;
        text-transform: uppercase;
        text-align: center;
        color: #1a1a1a;
        background: transparent;
        border: 1px dashed transparent;
        border-radius: 4px;
        width: 90%;
        padding: 4px 2px;
        letter-spacing: 0.3px;
        transition: all 0.2s;
    }
    .corner-input:hover { border-color: rgba(0,0,0,0.2); }
    .corner-input:focus { outline: none; border-color: var(--color-primary); background: rgba(255,255,255,0.8); font-size: 0.5rem; }
    .corner-bl { grid-column: 1; grid-row: 11; }
    .corner-tl { grid-column: 1; grid-row: 1; }
