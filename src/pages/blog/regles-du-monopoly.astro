---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<Layout
    title="Règles du Monopoly : le guide complet pour bien jouer"
    description="Toutes les règles officielles du Monopoly expliquées : achat, enchères, construction, loyers, prison, hypothèque et les 5 fausses règles courantes."
>
    <Navbar />
    <main>
        <article class="article">
            <header class="article-hero">
                <div class="container">
                    <Breadcrumb items={[
                        { label: "Accueil", href: "/" },
                        { label: "Blog", href: "/blog/" },
                        { label: "Règles du Monopoly" }
                    ]} />
                    <a href="/blog/" class="back-link">&larr; Retour au blog</a>
                    <div class="article-meta">
                        <span class="article-tag">Règles</span>
                        <time datetime="2026-03-28">28 mars 2026</time>
                        <span class="article-read">12 min de lecture</span>
                    </div>
                    <h1>Règles du Monopoly : le guide complet pour bien jouer</h1>
                    <p class="article-intro">Vous pensez connaître les règles du Monopoly ? Il y a de fortes chances que vous en appliquiez plusieurs fausses. Enchères obligatoires, pas d'argent au Parking Gratuit, pas de double salaire sur la case Départ... Voici les règles officielles, expliquées clairement.</p>
                </div>
            </header>

            <div class="article-body">
                <div class="container article-layout">
                    <aside class="toc-sidebar" aria-label="Table des matières">
                        <div class="toc-sticky">
                            <h3 class="toc-title">Sommaire</h3>
                        <ul class="toc-list">
                            <li><a href="#matériel">Le matériel</a></li>
                            <li><a href="#mise-en-place">Mise en place</a></li>
                            <li><a href="#tour">Déroulement d'un tour</a></li>
                            <li><a href="#achat">Acheter une propriété</a></li>
                            <li><a href="#enchères">Les enchères (la règle oubliée)</a></li>
                            <li><a href="#loyers">Payer un loyer</a></li>
                            <li><a href="#construction">Construire des maisons et des hôtels</a></li>
                            <li><a href="#cases-spéciales">Les cases spéciales</a></li>
                            <li><a href="#prison">La prison</a></li>
                            <li><a href="#hypothèque">L'hypothèque</a></li>
                            <li><a href="#faillite">La faillite</a></li>
                            <li><a href="#victoire">Conditions de victoire</a></li>
                            <li><a href="#erreurs">Les 5 fausses règles les plus répandues</a></li>
                        </ul>
                        </div>
                    </aside>
                    <div class="article-main">

                    <section id="matériel">
                        <h2>Le matériel</h2>
                        <p>Une boîte de Monopoly classique contient :</p>
                        <ul>
                            <li><strong>1 plateau de jeu</strong> avec 40 cases</li>
                            <li><strong>8 pions</strong> (chapeau, voiture, chien, fer à repasser, bateau, brouette, de à coudre, chat)</li>
                            <li><strong>28 cartes de titre de propriété</strong> (22 terrains, 4 gares, 2 compagnies)</li>
                            <li><strong>16 cartes Chance</strong> et <strong>16 cartes Caisse de communauté</strong></li>
                            <li><strong>32 maisons</strong> (vertes) et <strong>12 hôtels</strong> (rouges)</li>
                            <li><strong>2 des</strong> à 6 faces</li>
                            <li><strong>Billets de banque</strong> en 7 coupures : 1, 5, 10, 20, 50, 100 et 500 euros</li>
                        </ul>
                    </section>

                    <section id="mise-en-place">
                        <h2>Mise en place</h2>
                        <ol>
                            <li>Déposez le plateau au centre de la table</li>
                            <li>Placez les cartes Chance et Caisse de communauté face cachée sur les emplacements prévus</li>
                            <li>Chaque joueur choisit un pion et le place sur la case Départ</li>
                            <li>Désignez un joueur comme <strong>banquier</strong> (il peut aussi jouer)</li>
                            <li>Le banquier distribue à chaque joueur <strong>1 500 euros</strong> répartis ainsi :</li>
                        </ul>
                        <div class="money-table">
                            <table>
                                <thead>
                                    <tr><th>Coupure</th><th>Quantite</th><th>Total</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>500 euros</td><td>x 2</td><td>1 000 euros</td></tr>
                                    <tr><td>100 euros</td><td>x 4</td><td>400 euros</td></tr>
                                    <tr><td>50 euros</td><td>x 1</td><td>50 euros</td></tr>
                                    <tr><td>20 euros</td><td>x 1</td><td>20 euros</td></tr>
                                    <tr><td>10 euros</td><td>x 2</td><td>20 euros</td></tr>
                                    <tr><td>5 euros</td><td>x 1</td><td>5 euros</td></tr>
                                    <tr><td>1 euro</td><td>x 5</td><td>5 euros</td></tr>
                                    <tr><td colspan="2"><strong>Total</strong></td><td><strong>1 500 euros</strong></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <section id="tour">
                        <h2>Déroulement d'un tour</h2>
                        <p>Le joueur le plus âgé commence (ou celui qui fait le plus grand score aux des). A chaque tour :</p>
                        <ol>
                            <li><strong>Lancez les 2 des</strong> et avancez votre pion du nombre de cases correspondant</li>
                            <li><strong>Appliquez l'effet</strong> de la case sur laquelle vous atterrissez</li>
                            <li><strong>Si vous avez fait un double</strong> (les 2 des affichent le même chiffre) : rejouez</li>
                            <li><strong>Attention</strong> : 3 doubles consécutifs = direction la prison !</li>
                        </ul>

                        <div class="rule-highlight">
                            <strong>Règle importante :</strong> Chaque fois que vous passez par la case Départ ou que vous vous y arrêtez, la Banque vous verse un salaire de <strong>200 euros</strong>. Ni plus, ni moins. (Voir notre article dédié a <a href="/blog/case-départ-monopoly/">la case Départ</a>.)
                        </div>
                    </section>

                    <section id="achat">
                        <h2>Acheter une propriété</h2>
                        <p>Lorsque vous atterrissez sur un <strong>terrain, une gare ou une compagnie</strong> qui n'appartient à personne, deux options s'offrent à vous :</p>
                        <ol>
                            <li><strong>Acheter</strong> la propriété au prix indiqué sur le plateau, en payant la Banque. Vous recevez la carte de titre de propriété correspondante.</li>
                            <li><strong>Ne pas acheter</strong> : dans ce cas, la propriété est <strong>immédiatement mise aux enchères</strong> (voir section suivante).</li>
                        </ul>
                    </section>

                    <section id="enchères">
                        <h2>Les enchères (la règle oubliée)</h2>
                        <p>C'est probablement la <strong>règle la plus méconnue</strong> du Monopoly. Pourtant, elle est officielle et figure dans les règles de toutes les éditions.</p>

                        <div class="rule-highlight warning">
                            <strong>Règle officielle :</strong> Si un joueur décidé de ne pas acheter une propriété sur laquelle il a atterri, le banquier doit <strong>immédiatement</strong> la mettre aux enchères. <strong>Tous les joueurs</strong> peuvent enchérir, y compris celui qui a refuse d'acheter. La mise de départ est libre (elle peut commencer a 1 euro). Le plus offrant remporte la propriété.
                        </div>

                        <p>Cette règle change radicalement la dynamique du jeu : elle permet d'acquerir des propriétés à prix réduit et accélère considérablement les parties. C'est d'ailleurs pour ça que beaucoup de parties "maison" durent des heures : sans les enchères, les propriétés restent invendues trop longtemps.</p>
                    </section>

                    <section id="loyers">
                        <h2>Payer un loyer</h2>
                        <p>Quand vous atterrissez sur une propriété qui appartient à un adversaire, vous devez lui payer un loyer. Le montant depend du type de propriété :</p>

                        <h3>Terrains</h3>
                        <ul>
                            <li><strong>Terrain nu</strong> : loyer de base (indiqué sur la carte)</li>
                            <li><strong>Terrain nu avec monopole</strong> (le joueur possède toute la couleur) : loyer <strong>double</strong></li>
                            <li><strong>Avec maisons</strong> : loyer croissant selon le nombre de maisons (1 a 4)</li>
                            <li><strong>Avec hôtel</strong> : loyer maximum</li>
                        </ul>

                        <h3>Gares</h3>
                        <ul>
                            <li>1 gare possèdee : <strong>25 euros</strong></li>
                            <li>2 gares : <strong>50 euros</strong></li>
                            <li>3 gares : <strong>100 euros</strong></li>
                            <li>4 gares : <strong>200 euros</strong></li>
                        </ul>

                        <h3>Compagnies (Électricité / Eaux)</h3>
                        <ul>
                            <li>1 compagnie possèdee : <strong>4 fois</strong> le montant des des</li>
                            <li>2 compagnies possèdees : <strong>10 fois</strong> le montant des des</li>
                        </ul>

                        <div class="rule-highlight">
                            <strong>Subtilite :</strong> Le propriétaire doit <strong>réclamer</strong> le loyer avant que le joueur suivant ne lance les des. S'il oublie, tant pis pour lui ! Cette règle officielle est rarement appliquee en pratique.
                        </div>
                    </section>

                    <section id="construction">
                        <h2>Construire des maisons et des hôtels</h2>
                        <p>Pour construire, vous devez possèder <strong>tous les terrains d'une même couleur</strong> (un monopole).</p>

                        <h3>Maisons</h3>
                        <ul>
                            <li>Achetez des maisons auprès de la Banque au prix indiqué sur la carte</li>
                            <li>Vous devez <strong>construire uniformement</strong> : l'ecart entre le nombre de maisons sur chaque terrain du groupe ne peut pas dépasser 1</li>
                            <li>Maximum <strong>4 maisons</strong> par terrain</li>
                        </ul>

                        <h3>Hôtels</h3>
                        <ul>
                            <li>Quand un terrain a 4 maisons, vous pouvez les remplacer par <strong>1 hôtel</strong></li>
                            <li>Rendez les 4 maisons à la Banque et payez le prix d'un hôtel</li>
                            <li>Maximum <strong>1 hôtel</strong> par terrain</li>
                        </ul>

                        <h3>Penurie de maisons</h3>
                        <p>Le jeu contient <strong>32 maisons et 12 hôtels</strong>. Si le stock est épuisé, personne ne peut construire tant que des maisons ne sont pas rendues à la Banque. C'est une règle stratégique importante : acheter des maisons sans les transformer en hôtels peut bloquer les autrès joueurs.</p>
                    </section>

                    <section id="cases-spéciales">
                        <h2>Les cases spéciales</h2>

                        <h3>Case Départ</h3>
                        <p>Chaque passage par la case Départ (où arrêt dessus) rapporte <strong>200 euros</strong>. Contrairement à une croyance répandue, se poser pile sur la case Départ ne rapporte <strong>pas le double</strong>. Consultez notre <a href="/blog/case-départ-monopoly/">article dédié à la case Départ</a> pour tout savoir.</p>

                        <h3>Chance et Caisse de communauté</h3>
                        <p>Piochez la carte du dessus et appliquez ses instructions. Certaines cartes vous déplacent, d'autres vous font gagner où perdre de l'argent. La carte "Vous êtes libère de prison" peut être conservée.</p>

                        <h3>Impôts</h3>
                        <ul>
                            <li><strong>Impôt sur le revenu</strong> (case 5) : payez 200 euros à la Banque</li>
                            <li><strong>Taxe de luxe</strong> (case 39) : payez 100 euros à la Banque</li>
                        </ul>

                        <h3>Parking Gratuit</h3>
                        <p>Selon les règles officielles, cette case est une <strong>case neutre</strong> : il ne se passe absolument rien. Pas de cagnotte, pas de gain. Pour en savoir plus sur les variantes populaires, lisez notre <a href="/blog/parking-gratuit-monopoly/">article dédié au Parking Gratuit</a>.</p>

                        <h3>Allez en prison</h3>
                        <p>Si vous atterrissez sur cette case, allez directement en prison sans passer par la case Départ (pas de 200 euros).</p>
                    </section>

                    <section id="prison">
                        <h2>La prison</h2>
                        <h3>Comment y aller</h3>
                        <ul>
                            <li>Atterrir sur la case "Allez en prison"</li>
                            <li>Tirer une carte "Allez en prison"</li>
                            <li>Faire <strong>3 doubles consécutifs</strong> aux des</li>
                        </ul>

                        <h3>Comment en sortir</h3>
                        <ul>
                            <li><strong>Payer 50 euros</strong> de caution au debut de votre tour, puis lancer les des normalement</li>
                            <li><strong>Utiliser une carte</strong> "Vous êtes libère de prison"</li>
                            <li><strong>Faire un double</strong> aux des (vous avez 3 tentatives)</li>
                            <li>Après 3 tours sans double, vous <strong>devez</strong> payer 50 euros et sortir</li>
                        </ul>

                        <div class="rule-highlight">
                            <strong>À noter :</strong> En prison, vous pouvez toujours acheter et vendre des propriétés, construire des maisons et percevoir des loyers.
                        </div>
                    </section>

                    <section id="hypothèque">
                        <h2>L'hypothèque</h2>
                        <p>Si vous manquez d'argent, vous pouvez <strong>hypothèquer</strong> vos propriétés auprès de la Banque :</p>
                        <ul>
                            <li>Retournez la carte de propriété face cachée</li>
                            <li>La Banque vous verse la <strong>valeur hypothécaire</strong> (la moitie du prix d'achat)</li>
                            <li>Tant qu'une propriété est hypothèquee, elle ne rapporte <strong>aucun loyer</strong></li>
                            <li>Pour lever l'hypothèque, remboursez la valeur hypothécaire <strong>+ 10% d'intérêts</strong></li>
                        </ul>
                        <p>Vous devez vendre toutes les maisons et hôtels d'un groupe avant de pouvoir hypothèquer un terrain de ce groupe.</p>
                    </section>

                    <section id="faillite">
                        <h2>La faillite</h2>
                        <p>Un joueur fait faillite quand il ne peut plus payer une dette, même après avoir hypothèque toutes ses propriétés et vendu toutes ses maisons.</p>
                        <ul>
                            <li><strong>Faillite envers un autre joueur</strong> : le créancier reçoit toutes les propriétés et l'argent restant du joueur en faillite</li>
                            <li><strong>Faillite envers la Banque</strong> : toutes les propriétés sont remises aux enchères</li>
                        </ul>
                        <p>Le joueur en faillite est <strong>éliminé</strong> de la partie. Envie de rendre vos parties encore plus uniques ? Consultez notre guide pour <a href="/blog/comment-personnaliser-son-monopoly/">personnaliser votre propre Monopoly</a>.</p>
                    </section>

                    <section id="victoire">
                        <h2>Conditions de victoire</h2>
                        <p>Le dernier joueur encore en jeu (qui n'a pas fait faillite) <strong>remporte la partie</strong>.</p>
                        <p>Pour des parties plus courtes, vous pouvez fixer un temps limite au départ. À la fin du temps imparti, le joueur le plus riche (argent + valeur des propriétés + maisons et hôtels) gagne. Si vous souhaitez aller plus loin, découvrez <a href="/blog/histoire-du-monopoly/">l'histoire fascinante du Monopoly</a> et comment ce jeu mythique a évolué depuis plus d'un siècle.</p>
                    </section>

                    <section id="erreurs">
                        <h2>Les 5 fausses règles les plus répandues</h2>
                        <p>Voici les erreurs que presque tout le monde commet :</p>

                        <div class="myth-list">
                            <div class="myth">
                                <div class="myth-header">
                                    <span class="myth-badge false">FAUX</span>
                                    <h3>"On met l'argent des taxes au centre et celui qui tombé sur Parking Gratuit le récupère"</h3>
                                </div>
                                <p><strong>Règle officielle :</strong> Le Parking Gratuit est une case neutre. L'argent des taxes va à la Banque. <a href="/blog/parking-gratuit-monopoly/">En savoir plus</a></p>
                            </div>
                            <div class="myth">
                                <div class="myth-header">
                                    <span class="myth-badge false">FAUX</span>
                                    <h3>"Si on tombé pile sur la case Départ, on gagne 400 euros"</h3>
                                </div>
                                <p><strong>Règle officielle :</strong> On gagne toujours 200 euros, que l'on passe ou que l'on s'arrête sur la case Départ. <a href="/blog/case-départ-monopoly/">En savoir plus</a></p>
                            </div>
                            <div class="myth">
                                <div class="myth-header">
                                    <span class="myth-badge false">FAUX</span>
                                    <h3>"Si personne ne veut acheter un terrain, il reste libre"</h3>
                                </div>
                                <p><strong>Règle officielle :</strong> Si le joueur refuse d'acheter, le terrain est immédiatement mis aux enchères entre tous les joueurs.</p>
                            </div>
                            <div class="myth">
                                <div class="myth-header">
                                    <span class="myth-badge false">FAUX</span>
                                    <h3>"On ne peut pas acheter de propriétés au premier tour"</h3>
                                </div>
                                <p><strong>Règle officielle :</strong> Vous pouvez acheter des le premier tour. Rien dans les règles ne l'interdit.</p>
                            </div>
                            <div class="myth">
                                <div class="myth-header">
                                    <span class="myth-badge false">FAUX</span>
                                    <h3>"En prison, on ne peut rien faire"</h3>
                                </div>
                                <p><strong>Règle officielle :</strong> En prison, vous pouvez acheter, vendre, construire et percevoir des loyers normalement.</p>
                            </div>
                        </div>
                    </section>

                    <!-- CTA -->
                    <section class="cta-final">
                        <div class="cta-box">
                            <div class="cta-content">
                                <h3>Et si vous jouiez avec les règles de VOTRE quartier ?</h3>
                                <p><strong>Mon Quartier</strong> crée un jeu de plateau personnalisé avec les rues et les lieux de votre ville. Les règles restent les mêmes, mais le plateau raconte votre histoire.</p>
                                <a href="/#devis" class="btn btn-primary btn-lg">Demander un devis gratuit</a>
                            </div>
                        </div>
                    </section>

                    </div>
                </div>
            </div>
        </article>
    </main>
    <Footer />
    <script>
        document.querySelectorAll('.toc a').forEach(link => {
            link.addEventListener('click', (e) => {
                const id = link.getAttribute('href');
                const target = document.querySelector(id!);
                if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
            });
        });
    </script>
</Layout>

<style>
    .article-hero { padding: 130px 0 50px; background: linear-gradient(135deg, #f0f7f0 0%, #e8f5e9 100%); }
    .back-link { display: inline-block; font-size: 0.9rem; color: var(--color-primary); margin-bottom: 20px; font-weight: 500; }
    .back-link:hover { text-decoration: underline; }
    .article-meta { display: flex; align-items: center; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
    .article-tag { background: #2E7D32; color: #fff; padding: 4px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 600; }
    .article-meta time, .article-read { font-size: 0.85rem; color: var(--color-text-light); }
    .article-hero h1 { font-family: var(--font-heading); font-size: 2.4rem; color: var(--color-primary-dark); max-width: 800px; line-height: 1.2; margin-bottom: 16px; }
    .article-intro { font-size: 1.15rem; color: var(--color-text-light); max-width: 700px; line-height: 1.7; }
    .article-body { padding: 40px 0 80px; }
    .article-layout {
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 48px;
        max-width: 1100px;
    }
    .toc-sidebar {
        align-self: start;
    }
    .toc-sticky {
        position: sticky;
        top: 90px;
        background: var(--color-bg-light);
        border-radius: var(--radius);
        padding: 20px;
        border: 1px solid var(--color-border);
    }
    .toc-title {
        font-family: var(--font-heading);
        font-size: 0.95rem;
        color: var(--color-primary-dark);
        margin-bottom: 12px;
    }
    .toc-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .toc-list li a {
        font-size: 0.82rem;
        color: var(--color-text-light);
        line-height: 1.4;
        display: block;
        padding: 3px 0;
        transition: color 0.2s;
    }
    .toc-list li a:hover {
        color: var(--color-primary);
    }
    .article-main { max-width: 780px; }
    .article-content section { margin-bottom: 48px; }
    .article-content h2 { font-family: var(--font-heading); font-size: 1.8rem; color: var(--color-primary-dark); margin-bottom: 16px; padding-top: 16px; }
    .article-content h3 { font-family: var(--font-heading); font-size: 1.25rem; color: var(--color-primary-dark); margin: 24px 0 10px; }
    .article-content p { font-size: 1.05rem; line-height: 1.8; color: var(--color-text); margin-bottom: 14px; }
    .article-content ul, .article-content ol { margin: 12px 0 20px 24px; font-size: 1.05rem; line-height: 1.8; }
    .article-content li { margin-bottom: 8px; }
    .article-content a { color: var(--color-primary); text-decoration: underline; }
    .money-table { overflow-x: auto; margin: 16px 0; }
    table { width: 100%; max-width: 400px; border-collapse: collapse; font-size: 0.95rem; }
    th, td { padding: 10px 16px; text-align: left; border-bottom: 1px solid var(--color-border); }
    th { background: var(--color-primary-dark); color: #fff; font-family: var(--font-heading); }
    .rule-highlight { background: #E8F5E9; border-left: 4px solid #2E7D32; padding: 16px 20px; border-radius: 0 12px 12px 0; margin: 20px 0; font-size: 1rem; line-height: 1.7; }
    .rule-highlight.warning { background: #FFF3E0; border-left-color: #E65100; }
    .myth-list { display: flex; flex-direction: column; gap: 20px; margin: 20px 0; }
    .myth { background: #FFF; border: 1px solid var(--color-border); border-radius: 12px; padding: 20px; }
    .myth-header { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .myth-header h3 { font-family: var(--font-heading); font-size: 1.05rem; color: var(--color-text); margin: 0; }
    .myth-badge { padding: 3px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 700; }
    .myth-badge.false { background: #FFCDD2; color: #C62828; }
    .myth p { margin: 0; font-size: 0.95rem; color: var(--color-text-light); }
    .cta-box { background: linear-gradient(135deg, #1b4332, #2d6a4f); border-radius: 20px; padding: 40px; margin: 36px 0; }
    .cta-content { text-align: center; }
    .cta-content h3 { font-family: var(--font-heading); font-size: 1.5rem; color: #fff; margin: 0 0 12px; }
    .cta-content p { color: rgba(255,255,255,0.85); font-size: 1rem; margin-bottom: 16px; }
    @media (max-width: 768px) { .article-layout { grid-template-columns: 1fr; gap: 0; } .toc-sticky { position: static; margin-bottom: 24px; } .article-hero { padding: 110px 0 40px; } .article-hero h1 { font-size: 1.8rem; } .cta-box { padding: 28px 20px; } }
</style>
