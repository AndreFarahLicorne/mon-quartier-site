---
import BoardMockup from './BoardMockup.astro';
---

<section class="hero" id="accueil">
    <div class="container hero-container">
        <div class="hero-content">
            <h1>Votre quartier devient un <span class="highlight">jeu de société</span></h1>
            <p class="hero-subtitle">Créez un jeu de plateau unique inspiré du Monopoly, personnalisé avec les rues, les commerces et les lieux emblématiques de votre quartier.</p>
            <div class="hero-ctas">
                <a href="#devis" class="btn btn-primary btn-lg">Demander un devis gratuit</a>
                <a href="#concept" class="btn btn-outline btn-lg">Découvrir le concept</a>
            </div>
            <div class="hero-badges">
                <div class="badge">
                    <span class="badge-icon">🎨</span>
                    <span>100% personnalisable</span>
                </div>
                <div class="badge">
                    <span class="badge-icon">🎁</span>
                    <span>Idée cadeau originale</span>
                </div>
            </div>
        </div>
        <div class="hero-visual">
            <BoardMockup />
        </div>
    </div>
</section>
