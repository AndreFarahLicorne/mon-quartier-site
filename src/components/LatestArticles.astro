---
const articles = [
    {
        title: "Top 10 des jeux de notre enfance à personnaliser",
        slug: "top-10-jeux-enfance-a-personnaliser",
        tag: "Inspiration",
        tagColor: "#E65100",
    },
    {
        title: "Règles du Monopoly : le guide complet",
        slug: "regles-du-monopoly",
        tag: "Règles",
        tagColor: "#2E7D32",
    },
    {
        title: "Comment personnaliser son Monopoly",
        slug: "comment-personnaliser-son-monopoly",
        tag: "Guide",
        tagColor: "#2d6a4f",
    },
];
---

<section class="section section-light" id="articles">
    <div class="container">
        <div class="section-header">
            <h2>Nos derniers articles</h2>
            <p>Conseils, inspirations et règles du jeu pour aller plus loin.</p>
        </div>
        <div class="articles-row">
            {articles.map(article => (
                <a href={`/blog/${article.slug}/`} class="article-mini">
                    <span class="article-mini-tag" style={`background: ${article.tagColor};`}>{article.tag}</span>
                    <h3>{article.title}</h3>
                    <span class="article-mini-link">Lire l'article &rarr;</span>
                </a>
            ))}
        </div>
        <div class="articles-all">
            <a href="/blog/" class="btn btn-outline">Voir tous les articles</a>
        </div>
    </div>
</section>

<style>
    .articles-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-bottom: 32px;
    }
    .article-mini {
        background: var(--color-bg);
        border-radius: var(--radius-lg);
        padding: 24px;
        text-decoration: none;
        color: inherit;
        border: 1px solid var(--color-border);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .article-mini:hover {
        border-color: var(--color-primary);
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    }
    .article-mini-tag {
        display: inline-block;
        width: fit-content;
        color: #fff;
        padding: 3px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .article-mini h3 {
        font-family: var(--font-heading);
        font-size: 1.05rem;
        color: var(--color-primary-dark);
        line-height: 1.3;
        flex: 1;
    }
    .article-mini-link {
        font-family: var(--font-heading);
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--color-cta);
    }
    .article-mini:hover .article-mini-link {
        color: var(--color-cta-dark);
    }
    .articles-all {
        text-align: center;
    }
    @media (max-width: 768px) {
        .articles-row {
            grid-template-columns: 1fr;
        }
    }
</style>
